# TikiTakaFootyTV — API keys.  Copy this to `.env` and fill in.  NEVER commit `.env`.
# The scripting "brain" runs on the Claude Code SUBSCRIPTION — there is no Anthropic key here.

# ── Nano Banana / Gemini image API  (stat cards, thumbnails, graphics) ──────────
# Get at: https://aistudio.google.com  →  "Get API key"
# Free tier: ~500 images/day on Nano Banana (Gemini 2.5 Flash Image), no credit card.
# Nano Banana PRO (best text) needs billing enabled (~$0.13/img, half via Batch).
GEMINI_API_KEY=

# ── ElevenLabs  (voiceover) ────────────────────────────────────────────────────
# Get at: https://elevenlabs.io  →  Profile  →  API Keys
# ⚠️ FREE TIER HAS NO COMMERCIAL RIGHTS. A monetized page needs >= Starter ($5/mo),
#    which includes a commercial license. Do not ship free-tier VO on a monetized post.
ELEVENLABS_API_KEY=

# ── YouTube Data API v3  (outlier-discovery engine — later) ─────────────────────
# Enable at: https://console.cloud.google.com → APIs & Services → enable
#   "YouTube Data API v3" → Credentials → Create API key.  Free, 10k units/day.
#   Use the SAME Google account/project as GEMINI_API_KEY.
YOUTUBE_API_KEY=

# ── Posting (no API key needed for the DEFAULT path) ───────────────────────────
# DEFAULT hybrid poster:
#   • YouTube  → pipeline/upload_youtube.py  (official Data API; OAuth refresh token in
#                pipeline/.secrets/ — run its `auth`/`auth-finish` once, no key here).
#   • TikTok/IG → the attended `post-social` skill (Playwright MCP browser automation;
#                 log in once in the browser, no key here).
# LEGACY fallback only — Postiz (deploy/postiz/). If you run that stack instead, set:
# POSTIZ_API_KEY=
# POSTIZ_URL=http://localhost:4007
